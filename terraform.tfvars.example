default_service_name = "platform-prototype-ecommerce"

container_services = {
  platform-prototype-ecommerce = {
    image             = "502867101295.dkr.ecr.sa-east-1.amazonaws.com/platform-prototype:latest"
    container_port    = 3000
    desired_count     = 1
    cpu               = 256
    memory            = 512
    health_check_path = "/"
    path_patterns     = ["/*"]
  }
}
